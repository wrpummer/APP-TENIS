    "@mui/x-date-pickers": "^8.6.0",
    "@supabase/supabase-js": "^2.50.3",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-query-devtools": "^5.80.7",
    "date-fns": "^4.1.0",
    "dom-to-image-more": "^3.5.0",
    "jspdf": "^4.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "recharts": "^2.15.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.1",
